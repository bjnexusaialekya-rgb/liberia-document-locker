# Local/dev/staging Vault (docker-compose.vault.yml, dev mode).
# In production this token is never a long-lived root token — see README
# "Production key custody" section and src/vault-unseal-handover.ts.
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=dev-only-root-token-change-me
VAULT_DEV_ROOT_TOKEN_ID=dev-only-root-token-change-me
VAULT_TRANSIT_MOUNT=transit

# Optional — only set if using Vault Enterprise namespaces. Not used in dev mode.
# VAULT_NAMESPACE=

# Set to run test/vault-client.integration.test.ts against a real Vault.
# If unset or unreachable, integration tests are skipped automatically
# (see README "Testing" section) rather than failing the whole suite.
